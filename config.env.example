# nx-cleanup configuration
# Copy this file to .env and fill in your values
# Used by run.sh for scheduled/manual execution

NEXUS_URL=http://your-nexus-host:8081
NEXUS_REPO=dkr-4-test
NEXUS_USER=admin
NEXUS_PASS=changeme

# Number of latest tags to retain per image path
KEEP_LAST=2

# Optional: only process image paths containing this substring
# Leave empty to process all images
# Example: FILTER=appname/develop
FILTER=
